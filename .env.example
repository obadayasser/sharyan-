# Database
DATABASE_URL=postgresql://postgres:Obayas1234$@localhost:5432/sharyan?schema=public

# JWT

JWT_ACCESS_SECRET=sharyan-access-secret-change-me
JWT_REFRESH_SECRET=sharyan-refresh-secret-change-me
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
# App

PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
# SMS Provider

SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890
# Geo

DEFAULT_SEARCH_RADIUS_KM=5
EMERGENCY_SEARCH_RADIUS_KM=10
MAX_SEARCH_RADIUS_KM=50
# Donation

MIN_DONATION_INTERVAL_DAYS=56
POINTS_PER_DONATION=100

